{
  "manifest_version": 3,
  "name": "HomeScope",
  "short_name": "HomeScope",
  "version": "1.1.0",
  "author": "Risa Studio",
  "description": "591 租屋/售屋周邊分析工具：捷運、學校、嫌惡設施一鍵搜尋，支援收藏與看房比較",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://rent.591.com.tw/*",
    "https://sale.591.com.tw/*",
    "https://nominatim.openstreetmap.org/*",
    "https://www.liquid.net.tw/*",
    "https://maps.wra.gov.tw/*",
    "https://www.geologycloud.tw/*",
    "https://bff-market.591.com.tw/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://rent.591.com.tw/*"],
      "js": ["extractors/base.js", "extractors/591rent.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://sale.591.com.tw/home/house/detail/*"],
      "js": ["extractors/base.js", "extractors/591sale.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "imag/icon16.png",
    "32":  "imag/icon32.png",
    "48":  "imag/icon48.png",
    "128": "imag/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HomeScope",
    "default_icon": {
      "16":  "imag/icon16.png",
      "32":  "imag/icon32.png",
      "48":  "imag/icon48.png",
      "128": "imag/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
